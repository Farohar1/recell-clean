<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Browse — ReCell Mobile</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    body { background:#0A0A0F; color:#E8E8F0; font-family:'DM Sans',sans-serif; }
    h1,h2,h3 { font-family:'Syne',sans-serif; }
    .navbar { background:rgba(10,10,15,0.95)!important; border-bottom:1px solid rgba(255,255,255,0.07); }
    .card { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; color:#E8E8F0; transition:transform .2s; }
    .card:hover { transform:translateY(-4px); }
    .card-img-top { height:180px; object-fit:cover; border-radius:12px 12px 0 0; }
    .card-img-placeholder { background:rgba(255,255,255,0.03); height:180px; display:flex; align-items:center; justify-content:center; font-size:2.5rem; border-radius:12px 12px 0 0; }
    .price { background:linear-gradient(135deg,#7C3AED,#06B6D4); -webkit-background-clip:text; -webkit-text-fill-color:transparent; font-family:'Syne',sans-serif; font-weight:800; font-size:1.2rem; }
    .btn-purple { background:linear-gradient(135deg,#7C3AED,#06B6D4); border:none; color:#fff; font-family:'Syne',sans-serif; font-weight:600; border-radius:8px; }
    .btn-purple:hover { opacity:.85; color:#fff; }
    .form-control,.form-select { background:rgba(255,255,255,0.06)!important; border:1px solid rgba(255,255,255,0.1)!important; color:#E8E8F0!important; border-radius:8px; }
    .form-control::placeholder { color:rgba(232,232,240,0.4); }
    a { text-decoration:none; color:inherit; }
  </style>
</head>
<body>
  <nav class="navbar navbar-dark sticky-top px-4 py-3">
    <a class="navbar-brand fw-bold" href="http://localhost:5173" style="font-family:'Syne',sans-serif">
      📱 ReCell <span style="color:#A78BFA">Mobile</span>
    </a>
    <a href="http://localhost:5173" class="btn btn-purple btn-sm px-3">Go to App →</a>
  </nav>

  <div class="container py-5">
    <h1 class="mb-1">Browse Phones</h1>
    <p class="mb-4" style="color:rgba(232,232,240,0.5)">Server-rendered with EJS + Bootstrap 5 + jQuery</p>

    <form method="GET" action="/pages/browse" class="row g-3 mb-5" id="filterForm">
      <div class="col-md-5">
        <input type="text" name="q" class="form-control" placeholder="Search brand or model..."/>
      </div>
      <div class="col-md-3">
        <select name="brand" class="form-select">
          <option value="">All Brands</option>
          <% ['Apple','Samsung','Google','OnePlus','Xiaomi','Sony','Nokia','Motorola'].forEach(b => { %>
            <option><%= b %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <input type="number" name="maxPrice" class="form-control" placeholder="Max price €"/>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-purple w-100" id="searchBtn">Search</button>
      </div>
    </form>

    <p style="color:rgba(232,232,240,0.4);font-family:'Syne',sans-serif;font-size:.85rem">
      <%= listings.length %> listing<%= listings.length !== 1 ? 's' : '' %> found
    </p>

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
      <% listings.forEach(l => { %>
        <div class="col">
          <a href="http://localhost:5173/listing/<%= l.id %>">
            <div class="card h-100">
              <% if (l.image) { %>
                <img src="http://localhost:5173<%= l.image %>" class="card-img-top" alt="<%= l.title %>"/>
              <% } else { %>
                <div class="card-img-placeholder">📱</div>
              <% } %>
              <div class="card-body">
                <span class="badge bg-primary mb-2" style="border-radius:20px;font-size:.7rem"><%= l.condition %></span>
                <h6 style="font-family:'Syne',sans-serif"><%= l.title %></h6>
                <p class="price mb-1">€<%= l.price %></p>
                <small style="color:rgba(232,232,240,0.4)">📍 <%= l.location %> &nbsp;·&nbsp; 👁 <%= l.views %></small>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>

    <% if (listings.length === 0) { %>
      <div class="text-center py-5" style="color:rgba(232,232,240,0.4)">No listings found.</div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <script>
    $(document).ready(function () {
      $('#filterForm').on('submit', function () {
        $('#searchBtn').text('Searching...').prop('disabled', true);
      });
      $('.card').hide().each(function (i) {
        $(this).delay(i * 60).fadeIn(300);
      });
    });
  </script>
</body>
</html>
